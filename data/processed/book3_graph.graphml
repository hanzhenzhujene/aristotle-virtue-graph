  <data key="d2">self-indulgence</data>
  <data key="d3">self-indulgence</data>
  <data key="d4">["self-indulgence", "self-indulgent"]</data>
  <data key="d5">[]</data>
  <data key="d6">vice</data>
  <data key="d7">Self-indulgence is the culpable excess with respect to bodily pleasures.</data>
