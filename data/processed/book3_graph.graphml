<node id="voluntary-action">
  <data key="d2">voluntary-action</data>
  <data key="d3">the voluntary</data>
  <data key="d4">["the voluntary"]</data>
  <data key="d5">["voluntary action"]</data>
  <data key="d6">action</data>
  <data key="d7">The voluntary is what has its moving principle in the agent, with awareness of the particular circumstances.</data>
