<node id="temperance">
  <data key="d2">temperance</data>
  <data key="d3">temperance</data>
  <data key="d4">["temperance"]</data>
  <data key="d5">[]</data>
  <data key="d6">virtue</data>
  <data key="d7">Temperance is the mean with respect to bodily pleasures and the appetites attached to them.</data>
